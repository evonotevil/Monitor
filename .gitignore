# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# 环境变量（本地调试用）
.env
.env.local

# SQLite 临时文件
data/*.db-journal
data/*.db-wal
data/*.db-shm

# 日志（不入库，CI 产物查 Actions 日志即可）
data/*.log

# 本地测试产生的时间戳报告——不入库，CI 产物用 latest.* 和 archive/ 代替
reports/report_*.html
reports/report_*.pdf
reports/report_*.md
reports/weekly_*.html
reports/weekly_*.pdf
reports/weekly_*.md
# PDF 体积大（单文件 ~2MB）且可重新生成，不入库；飞书通知使用带日期命名 PDF 的 raw URL
# latest.pdf 每周覆盖会不断堆积 git 历史，改为本地/CI 产物，不提交
reports/latest.pdf
reports/Lilith-Legal-Compliance-Report-*.pdf

# 始终保留 latest HTML 和 每周存档目录（HTML 约 80KB，适合文本 diff）
!reports/latest.html
!reports/.gitkeep
!reports/archive/
!reports/archive/**

# macOS
.DS_Store

# IDE
.vscode/
.idea/
